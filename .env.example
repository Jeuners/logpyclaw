# AgentClaw v2 — Konfigurationsvorlage
# Kopiere diese Datei als .env und trage deine spezifischen Werte ein
# Alle mit = sind erforderlich, Kommentare zeigen Defaults

# === APP-KONFIGURATION ===
AGENTCLAW_PORT=5050
AGENTCLAW_HOST=0.0.0.0
AGENTCLAW_DEBUG=false
AGENTCLAW_NATIVE_MODE=true
AGENTCLAW_SECRET_KEY=change-me-in-production-with-a-random-string-32-chars-min

# === LOGGING ===
AGENTCLAW_LOG_LEVEL=INFO
AGENTCLAW_LOG_FILE=agentclaw.log
AGENTCLAW_LOG_FORMAT=json

# === CORS (für Web-Zugriff von anderen Domains) ===
# AGENTCLAW_CORS_ORIGINS=["http://localhost:5050", "http://localhost:3000"]

# === LOKALE SERVICES (Standard-Werte) ===
# Ollama für lokale LLM-Inference
AGENTCLAW_OLLAMA_URL=http://localhost:11434
AGENTCLAW_OLLAMA_MODEL=llama2

# ComfyUI für Image/Video Generation
AGENTCLAW_COMFYUI_URL=http://localhost:8188
AGENTCLAW_COMFYUI_TIMEOUT_SECONDS=300

# Qdrant für Vector-DB (Memory, Embedding-Storage)
AGENTCLAW_QDRANT_URL=http://localhost:6333
AGENTCLAW_QDRANT_API_KEY=

# Redis für Caching, Task-Queue, State
AGENTCLAW_REDIS_HOST=localhost
AGENTCLAW_REDIS_PORT=6379
AGENTCLAW_REDIS_DB=0
AGENTCLAW_REDIS_PASSWORD=

# === LIMITS & TIMEOUTS ===
AGENTCLAW_TASK_TIMEOUT_SECONDS=1200
AGENTCLAW_MAX_HISTORY_PER_AGENT=50
AGENTCLAW_MAX_CONCURRENT_TASKS=5
AGENTCLAW_SKILL_EXECUTION_TIMEOUT_SECONDS=300

# === CLOUD PROVIDER CREDENTIALS (optional) ===
# OpenAI
OPENAI_API_KEY=sk-...

# Mistral (für Voxtral TTS)
MISTRAL_API_KEY=

# OpenRouter (für Cloud-Modelle)
# OPENROUTER_API_KEY=

# YouTube
YOUTUBE_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail
GMAIL_USER_EMAIL=
GMAIL_APP_PASSWORD=

# LinkedIn
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# === FEATURE FLAGS ===
AGENTCLAW_ENABLE_MEMORY_SKILL=true
AGENTCLAW_ENABLE_WEBSEARCH_SKILL=true
AGENTCLAW_ENABLE_FILE_SKILL=true
AGENTCLAW_ENABLE_IMAGE_GENERATION=true
AGENTCLAW_ENABLE_VIDEO_GENERATION=true

# === PERSISTENCE ===
AGENTCLAW_SAVE_CHAT_HISTORY=true
AGENTCLAW_SAVE_TASKS=true
AGENTCLAW_HISTORY_DIR=./data/history
AGENTCLAW_TASKS_DIR=./data/tasks
AGENTCLAW_CONFIG_DIR=./data/config
