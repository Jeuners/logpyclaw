# LogpyClaw v3 — Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────────
# SQLite-Pfad (relativ zum Projektverzeichnis)
DB_URL=sqlite:///./logpyclaw.db
# Für In-Memory (kein Persist):
# DB_URL=sqlite:///:memory:

# ── Auth ───────────────────────────────────────────────────────────────────────
# Token für /ext/dilles/v1/* (leer = kein Auth)
WEB_BRIDGE_TOKEN=

# ── Martin QC ─────────────────────────────────────────────────────────────────
MARTIN_QC_ENABLED=true
MARTIN_QC_MIN_SCORE=7
MARTIN_QC_MAX_RETRIES=2
# Auditor-Agent-ID für QC-Loop (leer = QC deaktiviert)
MARTIN_QC_AUDITOR_ID=

# Deploy-Ziel für den deploy-Skill (rsync via SSH)
DEPLOY_SSH_HOST=user@your-server.example
DEPLOY_REMOTE_ROOT=/var/www/your-site
DEPLOY_PUBLIC_BASE=https://your-site.example
# WhatsApp Standard-Gruppe für den whatsapp-Skill
WHATSAPP_DEFAULT_GROUP=
